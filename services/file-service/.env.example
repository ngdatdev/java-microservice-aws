# AWS Configuration (Real AWS - dev/staging)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# AWS Resources (from CDK output)
AWS_S3_FILE_STORAGE_BUCKET_NAME=demo-uploads-dev
AWS_SNS_FILE_EVENTS_TOPIC_ARN=arn:aws:sns:ap-southeast-1:123456789012:file-events-dev

# Database (PostgreSQL in Docker)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=password
DB_NAME=file_db
