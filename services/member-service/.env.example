# AWS Configuration (Real AWS - dev/staging)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# AWS Resources (from CDK output)
AWS_SNS_MEMBER_EVENTS_TOPIC_ARN=arn:aws:sns:ap-southeast-1:123456789012:member-events-dev
AWS_SQS_AUDIT_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/123456789012/audit-queue-dev

# Database (PostgreSQL in Docker)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=password
DB_NAME=member_db
