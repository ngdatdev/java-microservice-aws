# AWS Configuration (Real AWS - dev/staging)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
# Or use 'aws sso login --profile aws-dev'

# AWS Resources (from CDK output)
AWS_SNS_MEMBER_EVENTS_TOPIC_ARN=arn:aws:sns:ap-southeast-1:123456789012:global-notifications-dev
AWS_SQS_MAIL_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/123456789012/mail-queue-dev
AWS_S3_FILE_STORAGE_BUCKET_NAME=demo-uploads-dev
COGNITO_USER_POOL_ID=ap-southeast-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Database (PostgreSQL in Docker)
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password
DB_NAME=auth_db # services will use their respective db names automatically
